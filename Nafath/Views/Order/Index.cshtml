@model IEnumerable<OrderDetailsViewModel>
@{
    ViewData["Title"] = "قائمة الطلبات";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;

}
<div class="wrapper container   ">
    <!--Content-Header-->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6 ">
                    
                    <ol class="breadcrumb  m-0 ">
                        <li class="breadcrumb-item ">إدارة الطلبات</li>
                        <li class="breadcrumb-item active"><a href="/Admin/Home/Index">الصفحة الرئيسية</a></li>
                    </ol>
                </div>
                <div class="col-sm-6">
                    <h1 class="text-dark float-sm-right">
                        قائمة الطلبات
                    </h1>
                 
                </div>
            </div>
        </div>
    </div>
    <!--End Content-Header-->
    <!-- Main content -->
    <section class="content">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">الطلبات</h4>
                    </div>
                    <div class="card-body">
                        @if (Model == null || !Model.Any()) 
                        {
                            <div class="alert alert-info">لا توجد طلبات متاحة</div>
                        }
                        else
                        {
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                       
                                        <th scope="col">رقم الطلب</th>
                                        <th scope="col">تاريخ الطلب</th>
                                        <th scope="col">الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                   
                                    @foreach (var orderVm in Model)
                                    {
                                        <tr>
                                            <td>
                                                # @(orderVm?.Order?.Id.ToString() ?? "N/A")
                                            </td>
                                            <td>
                                                @(orderVm?.Order?.OrderDate.ToString("yyyy-MM-dd HH:mm") ?? "N/A")
                                            </td>
                                            <td>
                                                @if (orderVm?.Order != null)
                                                {
                                                    <button type="button" class="btn btn-info" data-bs-toggle="modal" 
                                                            data-bs-target="#viewModal-@orderVm.Order.Id">
                                                        عرض التفاصيل
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        <!-- Pagination -->
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center w-100">
                                @{
                                    int prevPage = currentPage > 1 ? currentPage - 1 : 1;
                                    int nextPage = currentPage < totalPages ? currentPage + 1 : totalPages;
                                }

                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = prevPage })">السابق</a>
                                </li>

                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                                    </li>
                                }

                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = nextPage })">التالي</a>
                                </li>
                            </ul>
                        </nav>
                    </div>

                </div>
            </div>
        </div>
    </section>


</div>

<!-- View Modals -->
@if (Model != null && Model.Any())
{
    @foreach (var vm in Model)
    {
        if (vm?.Order != null)
        {
            <div class="modal fade dir " id="viewModal-@vm.Order.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            <h5 class="modal-title">تفاصيل الطلب</h5>
                        </div>
                        <div class="modal-body">
                          
                            @if (vm.Items != null && vm.Items.Any())
                            {
                                <table class="table table-striped mt-4">
                                    <thead>
                                        <tr>
                                            <th>صورة</th>
                                            <th>المنتج</th>
                                            <th>الكمية</th>
                                            <th>سعر الوحدة</th>
                                            <th>الإجمالي</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in vm.Items)
                                        {
                                            <tr>
                                                <td>
                                                    <img src="@Url.Content(item?.ImageUrl ?? "~/default-image.png")" 
                                                         alt="@item?.ProductName"
                                                         style="width:60px; height:60px; object-fit:cover;" />
                                                </td>
                                                <td>@(item?.ProductName ?? "N/A")</td>
                                                <td>@(item?.Quantity.ToString() ?? "N/A")</td>
                                                <td>@(item?.UnitPrice.ToString("N2") ?? "0.00")</td>
                                                <td>@(item?.TotalPrice.ToString("N2") ?? "0.00")</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <th colspan="4" class="text-end pt-5 ">المبلغ الكلي:    @vm.Items.Sum(i => i?.TotalPrice ?? 0).ToString() </th>
                                        </tr>
                                    </tfoot>
                                </table>
                            }
                            else
                            {
                                <div class="alert alert-warning">لا توجد بنود لهذا الطلب.</div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}