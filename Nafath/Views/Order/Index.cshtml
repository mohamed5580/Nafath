@model IEnumerable<OrderDetailsViewModel>
@{
    ViewData["Title"] = "قائمة الطلبات";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="wrapper container">
    <!-- Content Header -->
    <div class="content-header mb-4">
        <div class="row">
            <div class="col-sm-6">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item">إدارة الطلبات</li>
                    <li class="breadcrumb-item active">
                        <a href="/">الصفحة الرئيسية</a>
                    </li>
                </ol>
            </div>
            <div class="col-sm-6 text-sm-end">
                <h1 class="m-0">قائمة الطلبات</h1>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <section class="content">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">الطلبات</h4>
            </div>
            <div class="card-body">
                @Html.AntiForgeryToken()

                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info">لا توجد طلبات متاحة</div>
                }
                else
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>رقم الطلب</th>
                                <th>تاريخ الطلب</th>
                                <th>تفاصيل الطلب</th>
                                <th>تعديل الطلب</th>
                                <th>#</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vm in Model)
                            {
                                <tr>
                                    <td>#@vm.Order.Id</td>
                                    <td>@vm.Order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <button class="btn btn-info"
                                                data-bs-toggle="modal"
                                                data-bs-target="#viewModal-@vm.Order.Id">
                                            عرض التفاصيل
                                        </button>
                                    </td>
                                    <td>
                                        <button class="btn btn-warning"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal-@vm.Order.Id">
                                            تعديل الطلب
                                        </button>
                                    </td>
                                    <td>
                                        <button class="btn btn-link text-danger remove-order"
                                                data-id="@vm.Order.Id">
                                            &times;
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- Pagination -->
                    <nav>
                        <ul class="pagination justify-content-center">
                            @{
                                var prev = currentPage > 1 ? currentPage - 1 : 1;
                                var next = currentPage < totalPages ? currentPage + 1 : totalPages;
                            }
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = prev })">السابق</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = next })">التالي</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </section>
</div>


<!-- =============================================
     مودال تعديل الطلب (Edit Modal)
     ============================================= -->
@if (Model != null && Model.Any())
{
    foreach (var vm in Model)
    {
        <div class="modal fade" id="editModal-@vm.Order.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title ms-auto">تعديل الطلب #@vm.Order.Id</h5>
                        <button type="button" class="btn-close ml-0" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="table-responsive">
                            <table class="table text-center">
                                <thead>
                                    <tr>
                                        <th>المنتج</th>
                                        <th>السعر</th>
                                        <th>الكمية</th>
                                        <th>السعر الكلي</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody class="cart-item">
                                    <!-- يملأ ديناميكياً عند فتح المودال -->
                                </tbody>
                            </table>
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <h5>المبلغ الكلي: <span class="total-carts">0.00</span> EGP</h5>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="button"
                                class="btn btn-danger clear-carts"
                                data-order-id="@vm.Order.Id">
                            تفريغ السلة
                        </button>

                        <form id="editForm-@vm.Order.Id"
                              asp-controller="Order"
                              asp-action="UpdateOrder"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@vm.Order.Id" />
                            <input type="hidden" id="ItemsJson-@vm.Order.Id" name="itemsJson" />

                            <button type="button"
                                    class="btn btn-primary btnn-update-order"
                                    data-order-id="@vm.Order.Id">
                                حفظ التعديلات
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    }
}


<!-- =============================================
     مودال عرض التفاصيل (View Modal - Read Only)
     ============================================= -->
@if (Model != null && Model.Any())
{
    foreach (var vm in Model)
    {
        <div class="modal fade" id="viewModal-@vm.Order.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <div class="modal-header" >
                        <h5 class="modal-title">تفاصيل الطلب #@vm.Order.Id</h5>
                        <button class="btn-close ml-0" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        @if (vm.Items.Any())
                        {
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>صورة</th>
                                        <th>المنتج</th>
                                        <th>الكمية</th>
                                        <th>سعر الوحدة</th>
                                        <th>الإجمالي</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in vm.Items)
                                    {
                                        <tr>
                                            <td>
                                                <img src="@Url.Content(item.ImageUrl ?? "~/default-image.png")"
                                                     style="width:60px;height:60px;object-fit:cover;" />
                                            </td>
                                            <td>@item.ProductName</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.UnitPrice.ToString("N2")</td>
                                            <td>@item.TotalPrice.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="alert alert-warning">لا توجد بنود لهذا الطلب.</div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
                    </div>

                </div>
            </div>
        </div>
    }
}


@section Scripts {
    <script>
        // السلة الخاصة بالمودال المفتوح حالياً
        let editCart = [];

        $(function () {

            // ========== فتح مودال التعديل: جلب عناصر الطلب ==========
            $(document).on('show.bs.modal', '[id^="editModal-"]', function () {
                var modal = $(this);
                var orderId = this.id.split('-')[1];

                $.getJSON('/Order/GetOrderItems', { orderId: orderId }, function (data) {
                    // ✅ الـ map الصحيح — productId مش id
                    editCart = data.map(function (item) {
                        return {
                            productId: item.productId,   // المفتاح الوحيد للتعرف على العنصر
                            name:      item.name,
                            price:     Number(item.price),
                            count:     item.count,
                            imageUrl:  item.imageUrl
                        };
                    });

                    updateEditCart(modal);
                });
            });

            // ========== إعادة ضبط السلة عند إغلاق المودال ==========
            $(document).on('hidden.bs.modal', '[id^="editModal-"]', function () {
                editCart = [];
            });

            // ========== زيادة الكمية ==========
            $(document).on('click', '.btn-increment', function () {
                var productId = parseInt($(this).data('id'));
                editCart.forEach(function (item) {
                    if (item.productId === productId) {
                        item.count += 1;
                    }
                });
                updateEditCart($('.modal.show'));
            });

            // ========== إنقاص الكمية ==========
            $(document).on('click', '.btn-decrement', function () {
                var productId = parseInt($(this).data('id'));
                editCart.forEach(function (item) {
                    if (item.productId === productId && item.count > 1) {
                        item.count -= 1;
                    }
                });
                updateEditCart($('.modal.show'));
            });

            // ========== تغيير الكمية يدوياً ==========
            $(document).on('change', '.item-count', function () {
                var productId = parseInt($(this).data('id'));
                var cnt = parseInt($(this).val());
                if (cnt > 0) {
                    editCart.forEach(function (item) {
                        if (item.productId === productId) {
                            item.count = cnt;
                        }
                    });
                }
                updateEditCart($('.modal.show'));
            });

            // ========== حذف عنصر من السلة ==========
            $(document).on('click', '.btn-remove', function () {
                var productId = parseInt($(this).data('id'));
                editCart = editCart.filter(function (item) {
                    return item.productId !== productId;  // ✅ productId مش id
                });
                updateEditCart($('.modal.show'));
            });

            // ========== تفريغ السلة بالكامل ==========
            $(document).on('click', '.clear-carts', function (e) {
                e.preventDefault();
                editCart = [];
                updateEditCart($('.modal.show'));
            });

            // ========== حفظ التعديلات ==========
            $(document).on('click', '.btnn-update-order', function () {
                var orderId = $(this).data('order-id');

                var items = editCart.map(function (i) {
                    return {
                        productId: i.productId,
                        quantity:  i.count,
                        unitPrice: i.price
                    };
                });

                $('#ItemsJson-' + orderId).val(JSON.stringify(items));
                $('#editForm-' + orderId).submit();
            });

            // ========== حذف الطلب ==========
            $(document).on('click', '.remove-order', function (e) {
                e.preventDefault();
                var orderId = $(this).data('id');

                Swal.fire({
                    title: 'هل أنت متأكد من حذف الطلب؟',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'نعم، احذف',
                    cancelButtonText: 'إلغاء'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Order/DeleteConfirmed',
                            type: 'POST',
                            data: { id: orderId },
                            headers: {
                                'RequestVerificationToken':
                                    $('input[name="__RequestVerificationToken"]').first().val()
                            },
                            success: function () { location.reload(); },
                            error: function () {
                                Swal.fire('خطأ', 'حدث خطأ أثناء الحذف', 'error');
                            }
                        });
                    }
                });
            });
        });


        // =============================================
        // دالة تحديث عرض السلة داخل المودال
        // =============================================
        function updateEditCart(modal) {
            var tot = editCart.reduce(function (sum, item) {
                return sum + (item.price * item.count);
            }, 0);

            modal.find('.total-carts').text(tot.toFixed(2));

            if (editCart.length === 0) {
                modal.find('.cart-item')
                     .html('<tr><td colspan="5" class="text-center text-muted">سلة المشتريات فارغة</td></tr>');
                return;
            }

            var html = '';
            editCart.forEach(function (i) {
                html += `
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="${i.imageUrl || '/default-image.png'}"
                                     class="img-thumbnail"
                                     style="width:60px;height:60px;object-fit:cover;">
                                <span>${i.name}</span>
                            </div>
                        </td>
                        <td>${i.price.toFixed(2)} EGP</td>
                        <td>
                            <div class="input-group" style="max-width:160px; margin:auto;direction: ltr;">
                                <button type="button"
                                        class="btn btn-outline-secondary btn-decrement"
                                        data-id="${i.productId}">−</button>

                                <input type="number"
                                       class="form-control text-center item-count"
                                       value="${i.count}"
                                       min="1"
                                       data-id="${i.productId}">

                                <button type="button"
                                        class="btn btn-outline-secondary btn-increment"
                                        data-id="${i.productId}">+</button>
                            </div>
                        </td>
                        <td>${(i.price * i.count).toFixed(2)} EGP</td>
                        <td>
                            <button type="button"
                                    class="btn btn-link text-danger btn-remove"
                                    data-id="${i.productId}"
                                    title="حذف">
                                &times;
                            </button>
                        </td>
                    </tr>`;
            });

            modal.find('.cart-item').html(html);
        }
    </script>
    <script>
        document.querySelectorAll('.btnn-update-order').forEach(btn => {
            btn.addEventListener('click', () => {
                const name = btn.dataset.name;
                Swal.fire({
                    icon: 'success',
                    title: '@ResourceWeb.lbAdded',
                    text: `تم التعديل   ${name} .`,
                    timer: 5000,
                    showConfirmButton: false
                });
            });
        });
    </script>
}
