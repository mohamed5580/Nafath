@model IEnumerable<OrderDetailsViewModel>
@{
    ViewData["Title"] = "قائمة الطلبات";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="wrapper container">
    <!-- Content Header -->
    <div class="content-header mb-4">
        <div class="row">
            <div class="col-sm-6">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item">إدارة الطلبات</li>
                    <li class="breadcrumb-item active">
                        <a href="/">الصفحة الرئيسية</a>
                    </li>
                </ol>
            </div>
            <div class="col-sm-6 ">
                <h1 class="m-0">قائمة الطلبات</h1>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <section class="content">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">الطلبات</h4>
                <h6 class="card-title">سيتم التواصل معكم في أقرب وقت</h6>
            </div>
            <div class="card-body">
                @Html.AntiForgeryToken()

                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info">لا توجد طلبات متاحة</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover text-center text-nowrap">
                            <thead>
                                <tr>
                                    <th>رقم الطلب</th>
                                    <th>تاريخ الطلب</th>
                                    <th>حالة الطلب</th>
                                    <th>تفاصيل الطلب</th>
                                    <th>تعديل الطلب</th>
                                    <th>#</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vm in Model)
                                {
                                    <tr>
                                        <td>#@vm.Order.Id</td>
                                        <td>@vm.Order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@vm.Order.OrderStatus</td>
                                        <td>
                                            <button class="btn bg-gradient-success text-white btn-view-order"
                                                    data-order-id="@vm.Order.Id">
                                                عرض التفاصيل
                                            </button>
                                        </td>
                                        <td>
                                            <button class="btn btn-warning btn-edit-order"
                                                    data-order-id="@vm.Order.Id">
                                                تعديل الطلب
                                            </button>
                                        </td>
                                        <td>
                                            <button class="btn btn-link text-danger remove-order"
                                                    data-order-id="@vm.Order.Id">
                                                &times;
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <nav>
                        <ul class="pagination justify-content-center">
                            @{
                                var prev = currentPage > 1 ? currentPage - 1 : 1;
                                var next = currentPage < totalPages ? currentPage + 1 : totalPages;
                            }
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = prev })">السابق</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = next })">التالي</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </section>
</div>

<!-- ========== مودال عرض التفاصيل ========== -->
<div class="modal fade" id="viewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewModalTitle">تفاصيل الطلب</h5>
                <button type="button" class="btn-close ml-0" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="viewModalBody">
                <!-- سيتم ملؤها عبر JavaScript -->
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- ========== مودال تعديل الطلب ========== -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title ms-auto" id="editModalTitle">تعديل الطلب</h5>
                <button type="button" class="btn-close ml-0" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive table-scroll-wrapper">
                    <table class="table table-bordered table-hover text-center text-nowrap">
                        <thead class="thead-light">
                            <tr>
                                <th>المنتج</th>
                                <th>السعر</th>
                                <th>الكمية</th>
                                <th>السعر الكلي</th>
                                <th>إجراءات</th>
                            </tr>
                        </thead>
                        <tbody id="editCartBody">
                        </tbody>
                    </table>
                </div>                <div class="d-flex justify-content-end mt-3">
                    <h5>المبلغ الكلي: <span id="totalCarts">0.00</span> EGP</h5>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-danger clear-carts">تفريغ السلة</button>
                <form id="editForm" asp-controller="Order" asp-action="UpdateOrder" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" id="editOrderId" value="" />
                    <input type="hidden" name="itemsJson" id="editItemsJson" value="" />
                    <button type="button" class="btn btn-primary btn-save-edit">حفظ التعديلات</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // ========== تعريف كائن إدارة السلة المؤقتة ==========
            const editCart = {
                items: [],           // مصفوفة العناصر { productId, name, price, count, imageUrl }
                orderId: null,

                // جلب العناصر من الخادم
                loadItems: function (orderId) {
                    var self = this;
                    self.orderId = orderId;
                    $.getJSON('/Order/GetOrderItems', { orderId: orderId }, function (data) {
                        self.items = data.map(function (item) {
                            return {
                                productId: item.productId,
                                name: item.name,
                                price: Number(item.price),
                                count: item.count,
                                imageUrl: item.imageUrl
                            };
                        });
                        self.render();
                    });
                },

                // إضافة/تحديث الكمية
                setCount: function (productId, newCount) {
                    var item = this.items.find(i => i.productId === productId);
                    if (item) {
                        if (newCount > 0) {
                            item.count = newCount;
                        } else {
                            // إذا كانت الكمية 0 أو أقل، نحذف العنصر
                            this.items = this.items.filter(i => i.productId !== productId);
                        }
                        this.render();
                    }
                },

                // زيادة الكمية
                increment: function (productId) {
                    var item = this.items.find(i => i.productId === productId);
                    if (item) {
                        item.count += 1;
                        this.render();
                    }
                },

                // إنقاص الكمية
                decrement: function (productId) {
                    var item = this.items.find(i => i.productId === productId);
                    if (item && item.count > 1) {
                        item.count -= 1;
                        this.render();
                    }
                },

                // حذف عنصر
                removeItem: function (productId) {
                    this.items = this.items.filter(i => i.productId !== productId);
                    this.render();
                },

                // تفريغ السلة بالكامل
                clear: function () {
                    this.items = [];
                    this.render();
                },

                // حفظ التعديلات (إرسال النموذج)
                save: function () {
                    var itemsJson = JSON.stringify(this.items.map(i => ({
                        productId: i.productId,
                        quantity: i.count,
                        unitPrice: i.price
                    })));
                    $('#editOrderId').val(this.orderId);
                    $('#editItemsJson').val(itemsJson);
                    $('#editForm').submit();
                },

                // عرض السلة في المودال
                render: function () {
                    var tbody = $('#editCartBody');
                    var totalSpan = $('#totalCarts');

                    if (this.items.length === 0) {
                        tbody.html('<tr><td colspan="5" class="text-center text-muted">سلة المشتريات فارغة</td></tr>');
                        totalSpan.text('0.00');
                        return;
                    }

                    var total = 0;
                    var html = '';
                    var self = this;
                    this.items.forEach(function (item) {
                        var itemTotal = item.price * item.count;
                        total += itemTotal;
                               html += `
                                    <tr style="direction: ltr;" class="align-middle">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <h6 class="mb-0">${item.name}</h6>
                                                <img src="${item.imageUrl || '/default-image.png'}" alt="${item.name}" class="img-thumbnail ms-3" style="width:60px;height:60px;object-fit:cover;">
                                            </div>
                                        </td>
                                        <td>${item.price.toFixed(2)} EGP</td>
                                        <td>
                                            <div class="input-group mx-auto" style="width: 140px;">
                                                <button class="btn btn-outline-secondary btn-decrement" data-product-id="${item.productId}">-</button>
                                                <input type="text" class="form-control text-center item-count" value="${item.count}" data-product-id="${item.productId}">
                                                <button class="btn btn-outline-secondary btn-increment" data-product-id="${item.productId}">+</button>
                                            </div>
                                        </td>
                                        <td>${itemTotal.toFixed(2)} EGP</td>
                                        <td>
                                            <button class="btn btn-link text-danger btn-remove-item" data-product-id="${item.productId}">&times;</button>
                                        </td>
                                    </tr>
                                `;
                    });

                    tbody.html(html);
                    totalSpan.text(total.toFixed(2));
                }
            };

            // ========== فتح مودال التعديل ==========
            $(document).on('click', '.btn-edit-order', function () {
                var orderId = $(this).data('order-id');
                $('#editModalTitle').text('تعديل الطلب #' + orderId);
                editCart.loadItems(orderId);
                $('#editModal').modal('show');
            });

            // ========== أحداث السلة ==========
            $(document).on('click', '.btn-increment', function () {
                var productId = parseInt($(this).data('product-id'));
                editCart.increment(productId);
            });

            $(document).on('click', '.btn-decrement', function () {
                var productId = parseInt($(this).data('product-id'));
                editCart.decrement(productId);
            });

            $(document).on('change', '.item-count', function () {
                var productId = parseInt($(this).data('product-id'));
                var val = parseInt($(this).val());
                if (!isNaN(val) && val >= 0) {
                    editCart.setCount(productId, val);
                } else {
                    // إذا كانت القيمة غير صالحة نعيد العرض السابق
                    editCart.render();
                }
            });

            $(document).on('click', '.btn-remove-item', function () {
                var productId = parseInt($(this).data('product-id'));
                editCart.removeItem(productId);
            });

            $(document).on('click', '.clear-carts', function (e) {
                e.preventDefault();
                editCart.clear();
            });

            // ========== حفظ التعديلات ==========
            $(document).on('click', '.btn-save-edit', function () {
                editCart.save();
                // بعد الإرسال سيتم إعادة تحميل الصفحة أو تحديثها، ولكن نعرض رسالة نجاح
                Swal.fire({
                    icon: 'success',
                    title: 'تم التعديل',
                    text: 'تم تحديث الطلب بنجاح.',
                    timer: 3000,
                    showConfirmButton: false
                });
                // سيتم إعادة التوجيه بعد الـ submit، لكننا نغلق المودال فوراً
                $('#editModal').modal('hide');
            });

            // ========== عرض تفاصيل الطلب ==========
            $(document).on('click', '.btn-view-order', function () {
                var orderId = $(this).data('order-id');
                $('#viewModalTitle').text('تفاصيل الطلب #' + orderId);
                $('#viewModalBody').html('<div class="text-center"><i class="fa fa-spinner fa-spin fa-2x"></i></div>');
                $('#viewModal').modal('show');

                $.getJSON('/Order/GetOrderItems', { orderId: orderId }, function (data) {
                    if (data.length === 0) {
                        $('#viewModalBody').html('<div class="alert alert-warning">لا توجد بنود لهذا الطلب.</div>');
                        return;
                    }

                    var html = `
                        <div class="table-responsive table-scroll-wrapper">
                            <table class="table text-center">
                                <thead>
                                    <tr>
                                        <th>صورة</th>
                                        <th>المنتج</th>
                                        <th>الكمية</th>
                                        <th>سعر الوحدة</th>
                                        <th>الإجمالي</th>
                                    </tr>
                                </thead>
                                <tbody>
                    `;
                    data.forEach(function (item) {
                        html += `
                            <tr>
                                <td>
                                    <img src="${item.imageUrl || '/default-image.png'}" style="width:60px;height:60px;object-fit:cover;" />
                                </td>
                                <td>${item.name}</td>
                                <td>${item.count}</td>
                                <td>${Number(item.price).toFixed(2)}</td>
                                <td>${(item.price * item.count).toFixed(2)}</td>
                            </tr>
                        `;
                    });
                    html += `
                                </tbody>
                            </table>
                        </div>
                    `;
                    $('#viewModalBody').html(html);
                }).fail(function () {
                    $('#viewModalBody').html('<div class="alert alert-danger">حدث خطأ أثناء تحميل التفاصيل</div>');
                });
            });

            // ========== حذف الطلب ==========
            $(document).on('click', '.remove-order', function (e) {
                e.preventDefault();
                var orderId = $(this).data('order-id');

                Swal.fire({
                    title: 'هل أنت متأكد من حذف الطلب؟',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'نعم، احذف',
                    cancelButtonText: 'إلغاء'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Order/DeleteConfirmed',
                            type: 'POST',
                            data: { id: orderId },
                            headers: {
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
                            },
                            success: function () {
                                location.reload();
                            },
                            error: function () {
                                Swal.fire('خطأ', 'حدث خطأ أثناء الحذف', 'error');
                            }
                        });
                    }
                });
            });

            // ========== إعادة ضبط السلة عند إغلاق مودال التعديل ==========
            $('#editModal').on('hidden.bs.modal', function () {
                editCart.items = [];
                editCart.orderId = null;
            });
        });
    </script>
}