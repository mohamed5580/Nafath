@using Domin.Entity

@inject Infrastructure.IRepository.Base.IRepository<ProductType> TypeRepo

@{
    var productTypes = await TypeRepo.FindAllasync();
}

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager


<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#61daff">
    <meta name="description" content="We will simple add to cart using javascript localstorage">
    <meta name="keywords" content="add to cart, add to cart javascript, localstorage add to cart, ecommerce shopping javascript, shooping cart demo">
    <meta name="author" content="Rajamanickam">

   

    <title>Nafath </title>

    <link rel="stylesheet" href="~/Admin/assets/css/backend-plugin.min.css">
    <link rel="stylesheet" href="~/Admin/assets/css/backend.css?v=1.0.0">
    <link rel="stylesheet" href="~/Admin/assets/vendor/@@fortawesome/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="~/Admin/assets/vendor/line-awesome/dist/line-awesome/css/line-awesome.min.css">
    <link rel="stylesheet" href="~/Admin/assets/vendor/remixicon/fonts/remixicon.css">

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="~/Nafas/assets/images/logoo.png">
    <link rel="stylesheet" href="~/Admin/plugins/sweetalert2/sweetalert2.min.css">
    <!-- Fonts -->
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect">
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">



    <link href="~/Nafas/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Nafas/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Nafas/assets/vendor/aos/aos.css" rel="stylesheet">
    <link href="~/Nafas/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="~/Nafas/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

    <link href="~/Nafas/assets/css/style.css" rel="stylesheet">
  
    <link href="~/Nafas/assets/css/main.css" rel="stylesheet">
</head>

<body class="index-page">

    <header id="header" class="header d-flex sticky-top ">
        <div class="container-fluid container-xl position-relative d-flex align-items-center">

            <a asp-area="" asp-controller="Home" asp-action="Index" class="logo d-flex ">
                <img src="~/Nafas/assets/images/logoo.png" alt="">
            </a>

            <nav id="navmenu" class="navmenu">
                <ul>
                    <li class="nav-item active">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link ">الرئيسية</a>
                    </li>

              
                    <li class="dropdown">
                        <a class="toggle-dropdown">
                            <span class="toggle-dropdown shoptext" >المتجر</span>
                            <i class="bi bi-chevron-down toggle-dropdown"></i>
                        </a>
                        <ul>
                            @foreach (var type in productTypes)
                            {
                                <li>
                                    <a asp-controller="Products"
                                           asp-action="Index"
                                           asp-route-typeId="@type.Id">
                                        @type.Name
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>

                    <li><a asp-area="" asp-controller="Home" asp-action="About" class="nav-link" >من نحن</a></li>
                    <li class=""><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Services">الخدمات</a></li>
                    <li><a class="nav-link" href="https://www.facebook.com/friends/requests/?profile_id=61573614235805">اتصل بنا</a></li>
                    <li class="dropdown">
                      
                    </li>
                    <li></li>
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
               
            </nav>

     
            <!-- CART MODAL -->
            <div class="modal fade " id="cartModal"
                 data-bs-backdrop="false"
                 tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg  ">
                    <div class="modal-content">

                        <div class="modal-header">
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            <h5 id="cartModalLabel" class="ms-auto">سلة المشتريات</h5>
                        </div>
                        <div class="modal-body">
                            <div class="table-responsive">
                                <div class="table-responsive">
                                    <table class="table table-hover text-center text-nowrap">
                                        <thead class="thead-light">
                                            <tr>
                                                <th>المنتج</th>
                                                <th>السعر</th>
                                                <th>الكمية</th>
                                                <th>السعر الكلي</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody class="cart-items">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-4">
                                <h4 style="color:#6a6a6a">
                                    المبلغ الكلي: <span class="total-cart">0.00</span> EGP
                                </h4>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">متابعة الشراء</button>
                            <button type="button" class="btn btn-danger clear-cart">تفريغ</button>
                            
                            <a asp-controller="Order"
                                   asp-action="Checkout"
                                   class="btn btn-primary">
                                اتمام الشراء
                            </a>

                        </div>
                    </div>
                </div>
            </div>

            <!-- LOGIN MODAL -->
            <div class="modal fade" id="loginModal" data-bs-backdrop="static" data-bs-keyboard="false"
                 tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">

                        <div class="modal-header">
                            <h5 class="modal-title" id="loginModalLabel">تسجيل الدخول</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <partial name="_LoginPartial" />
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>

                    </div>
                </div>
            </div>


        </div>

        <ul class="navbar-nav flex-row align-items-center iconNav">
            <!-- User Icon Dropdown -->
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                       data-bs-toggle="dropdown" aria-expanded="false">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        var imgUrl = string.IsNullOrEmpty(currentUser?.AvatarFile)
                            ? $"{Helper.PathImageuser}user1.jpg"
                            : currentUser.AvatarFile;

                        if (!imgUrl.StartsWith("~/") && !imgUrl.StartsWith("/") &&
                            !imgUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) &&
                            !imgUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
                        {
                            imgUrl = $"{Helper.PathImageuser}{imgUrl}";
                        }

                        <img src="@(Url.Content(imgUrl))"
                             alt="Profile"
                             class="rounded-circle"
                             style="width:50px;height:50px;" />
                    }
                    else
                    {
                        <img src="~/Nafas/assets/images/user.png"
                             alt="Profile"
                             class="rounded-circle"
                             style="width:50px;height:50px;" />
                    }

                   
                </a>
                <ul class="dropdown-menu dropdown-menu-end p-3 " aria-labelledby="userDropdown">
                    <!-- هنا ضع خيارات المستخدم أو partial login -->
                    <partial name="_LoginPartial" />
                </ul>
            </li>

            <!-- Cart Icon Modal Trigger -->

            <li class="nav-item">
                <a class="nav-link position-relative" data-bs-toggle="modal" data-bs-target="#cartModal">
                    <i class="bi bi-cart3 fs-4"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cart-badge">0</span>
                </a>
            </li>
        </ul>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer id="footer" class="footer">

        <div class="footer-newsletter">
            <div class="container">
                <div class="row justify-content-center text-center">
                    <div class="col-lg-6">
                        <h4>اشترك في النشرة الإخبارية</h4>
                        <p>اشترك في نشرتنا الإخبارية وتلق أحدث الأخبار حول منتجاتنا وخدماتنا!</p>
                        <form action="forms/newsletter.php" method="post" class="php-email-form">
                            <div class="newsletter-form"><input type="email" name="email" placeholder="البريد الإلكتروني"><input type="submit" value="اشترك"></div>
                            <div class="loading">جاري التحميل</div>
                            <div class="error-message"></div>
                            <div class="sent-message">تم إرسال طلب الاشتراك. شكراً لك!</div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="container footer-top">
            <div class="row gy-4">
                <div class="col-lg-4 col-md-6 footer-about">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="logo d-flex ">
                        <img src="~/Nafas/assets/images/logoo.png" class="w-25" alt="">
                        <h1 class="sitename">نفاذ</h1>
                    </a>
                    <div class="footer-contact pt-3">
                        <p>برج ستي ستار</p>
                        <p>  6 أكتوبر </p>
                        <p class="mt-3"><strong>الهاتف:</strong> <span>01126499600</span></p>
                    </div>
                </div>

                <div class="col-lg-2 col-md-3 footer-links">
                    <h4>روابط مفيدة</h4>
                    <ul>
                        <li><i class="bi bi-chevron-right"></i> <a asp-area="" asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                        <li><i class="bi bi-chevron-right"></i> <a asp-area="" asp-controller="Home" asp-action="About">من نحن</a></li>
                        <li><i class="bi bi-chevron-right"></i> <a asp-area="" asp-controller="Home" asp-action="Services">الخدمات</a></li>
                        <li><a class="nav-link" href="https://www.facebook.com/friends/requests/?profile_id=61573614235805">اتصل بنا</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-3 footer-links">
                    <h4>خدماتنا</h4>
                    <ul>
                        <li><i class="bi bi-chevron-right"></i> <a href="#">تصميم المواقع</a></li>
                        <li><i class="bi bi-chevron-right"></i> <a href="#">تطوير المواقع</a></li>
                        <li><i class="bi bi-chevron-right"></i> <a href="#">إدارة المنتجات</a></li>
                        <li><i class="bi bi-chevron-right"></i> <a href="#">التسويق</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-12">
                    <h4>تابعنا</h4>
                    <p>تابعنا على وسائل التواصل الاجتماعي للحصول على آخر التحديثات.</p>
                    <div class="social-links d-flex">
                        <a href=""><i class="bi bi-twitter-x"></i></a>
                        <a href=""><i class="bi bi-facebook"></i></a>
                        <a href=""><i class="bi bi-instagram"></i></a>
                        <a href=""><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>

            </div>
        </div>

        <div class="container copyright text-center mt-4">
            <p>© <span>حقوق النشر</span> <strong class="px-1 sitename">Nafas</strong> <span>جميع الحقوق محفوظة</span></p>
           
        </div>

    </footer>

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <!-- Preloader -->
    <div id="preloader"></div>
    <script src="~/Admin/plugins/jquery/jquery.min.js"></script>
    <!-- Vendor JS Files -->
    <script src="~/Nafas/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Nafas/assets/vendor/php-email-form/validate.js"></script>
    <script src="~/Nafas/assets/vendor/aos/aos.js"></script>
    <script src="~/Nafas/assets/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="~/Nafas/assets/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="~/Nafas/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
    <script src="~/Nafas/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/Nafas/assets/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/Admin/plugins/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/Nafas/assets/js/sweetalert.js"></script>
    <script src="~/Nafas/assets/js/main.js"></script>

    <script>
            document.addEventListener('DOMContentLoaded', function () {
                const cartModal = document.getElementById('cartModal');
                const mainContent = document.querySelector('.main-content');

                if (cartModal && mainContent) {
                    cartModal.addEventListener('show.bs.modal', function () {
                        mainContent.classList.add('blurred');
                    });

                    cartModal.addEventListener('hidden.bs.modal', function () {
                        mainContent.classList.remove('blurred');
                    });
                }
            });
    </script>

    @if (SignInManager.IsSignedIn(User))
    {
        <script src="~/Nafas/assets/js/cart.js"></script>
    }
    else
    {
        <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const cartItems = document.querySelector('.cart-items');
                    if (cartItems) {
                        cartItems.innerHTML = '<tr><td colspan="5" class="text-center">Your cart is empty</td></tr>';
                    }
                });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>

