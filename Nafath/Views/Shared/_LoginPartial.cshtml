@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager


@if (SignInManager.IsSignedIn(User))
{
    <div class="d-block align-items-center text-center">

        <a id="manage" class="nav-link " asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage"> @UserManager.GetUserName(User) ! مرحبا</a>
        <hr>
        <a id="manage" class="nav-link " asp-area="" asp-controller="Order" asp-action="Index" title=""> سلة المشتريات</a>
        <hr>
   

        <form id="logoutForm" class="d-block  mt-3 align-items-center" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" onsubmit="localStorage.removeItem('shoppingCart'); localStorage.removeItem('cart');">
            <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">الملف الشخصي</a>
            <li><hr class="dropdown-divider"></li>
             <button type="submit" class="dropdown-item">تسجيل الخروج</button>
        </form>
    </div>

}
else
{
    <div class="align-items-center text-center">
        <li><a class="dropdown-item  " asp-area="Identity" asp-page="/Account/Register">تسجيل</a></li>
        <li><hr class="dropdown-divider  "></li>
        <li><a class="dropdown-item " asp-area="Identity" asp-page="/Account/Login">تسجيل الدخول</a></li>

    </div>
 }


