@model IEnumerable<Domin.Entity.Chairs>
@using Microsoft.AspNetCore.Identity
@using Domin.Entity
@using Domin.Resource
@{
    ViewData["Title"] = "Index";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<partial name="_Notifications" />

<!-- Start Hero Section -->
<div class="hero">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Shop</h1>
                </div>
            </div>
            <div class="col-lg-2 text-right">
                <!-- Cart button -->
                <button class="btn btn-outline-info position-relative" data-bs-toggle="modal" data-bs-target="#cartModal">
                    <i class="bi bi-cart"></i> Cart
                </button>
            </div>
        </div>
    </div>
</div>
<!-- End Hero Section -->

<div class="container m">
    <div class="content-page">
        <div class="container-fluid bg b-radius">
            <!-- HEADER -->
            <div class="row mb-4">
                <div lang="ar" dir="rtl" class="col-lg-12 d-flex align-items-center justify-content-between">
                    <div class="pt-5">
                        <h1 class="mb-1">كراسي المكتب</h1>
                        <p class="mb-0">أثاث مكتبي مميز: من الكراسي المريحة</p>
                    </div>
                </div>
            </div>
            <hr />
            <div class="untree_co-section product-section before-footer-section">
                <div class="container ">
                    <div class="row">
                        @foreach (var chair in Model)
                        {
                            <div class="col-12 col-md-4 col-lg-3 mb-5">
                                <a class="product-item" href="#" data-bs-toggle="modal" data-bs-target="#viewModal-@chair.Id">
                                    <input type="hidden" name="Id" value="@chair.Id" />
                                    <img src="@chair.ImageUrl" alt="@chair.Name" class="img-fluid product-thumbnail" />
                                    <h3 class="product-title">@chair.Name</h3>
                                    <strong class="product-price">@chair.Price EGP</strong>
                                    <span class="icon-cross">
                                        <svg style="width:26px; height:26px; margin-top:5px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="#ffffff">
                                            <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                                            <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
                                            <g id="SVGRepo_iconCarrier">
                                                <path d="M12 20H16M12 20H8M12 20V16M12 16H5C4.44772 16 4 15.5523 4 15V6C4 5.44771 4.44772 5 5 5H19C19.5523 5 20 5.44772 20 6M12 16H19C19.5523 16 20 15.5523 20 15V10" stroke="#ffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                            </g>
                                        </svg>
                                    </span>
                                </a>
                            </div>
                        }



                    </div>

                    <!-- Pagination -->
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center w-100">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@(currentPage > 1 ? Url.Action("Index", new { page = currentPage - 1 }) : "#")">Previous</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@(currentPage<totalPages? Url.Action("Index", new { page = currentPage + 1 }) : "#")">Next</a>
                            </li>
                        </ul>
                    </nav>


                </div>
            </div>
        </div>
    </div>
</div>

<!-- VIEW MODALS -->
@foreach (var chair in Model)
{
    <div  class="modal fade" id="viewModal-@chair.Id" tabindex="-1" aria-labelledby="viewModalLabel-@chair.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header ">
                    <h5 class="modal-title ms-auto" id="viewModalLabel-@chair.Id">شاشة العرض</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="row text-right p-3">
                        <div class="col-md-6">
                            <img src="@chair.ImageUrl" alt="@chair.Name" class="img-fluid" />
                        </div>
                        <div class="col-md-6 rtl">
                            <h3>@chair.Name</h3>
                            <p class="product-price">@chair.Price EGP <strong>:السعر</strong></p>
                            <p><strong>متوفر:</strong> @(chair.IsAvailable ? "نعم" : "لا")</p>
                            <p>@chair.Description</p>

                            @if (SignInManager.IsSignedIn(User))
                            {
                                <button type="button"
                                        data-name="@chair.Name"
                                        data-price="@chair.Price"
                                        data-imageurl="@chair.ImageUrl"
                                        data-id="@chair.Id"
                                        class="btn btn-primary add-to-cart">
                                    Add to cart
                                </button>
                            }
                            else
                            {
                                <a asp-area="Identity"
                                   asp-page="/Account/Login"
                                   asp-route-returnUrl="@Context.Request.Path"
                                   class="btn btn-primary">
                                    Login to add cart
                                </a>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
            <script>
                // Listen for *any* modal being fully hidden
                $(document).on('hidden.bs.modal', function () {
                  // Remove the backdrop element(s)
                  $('.modal-backdrop').remove();
                  // Remove the class that prevents page scrolling
                  $('body').removeClass('modal-open');
                });
            </script>

        </div>
    </div>
}

<!-- CART MODAL -->
<div class="modal fade" id="cartModal" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cartModalLabel">سلة المشتريات</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-hover text-center">
                        <thead class="thead-light">
                            <tr>
                                <th>المنتج</th>
                                <th>السعر</th>
                                <th>الكمية</th>
                                <th>السعر الكلي</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody class="cart-items">
                            <!-- Cart items will be populated here -->
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-end mt-4">
                    <h4 style="color:#6a6a6a">
                        المبلغ الكلي: <span class="total-cart">0.00</span> EGP
                    </h4>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">متابعة الشراء</button>
                <button type="button" class="btn btn-danger clear-cart">تفريغ</button>
                <button type="button" class="btn btn-primary">اتمام الشراء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
  
}
