@model IEnumerable<Domin.Entity.Chairs>
@using Domin.Resource
@inject IWebHostEnvironment Env 

@{
    ViewData["Title"] = "Index";
}

<partial name="_Notifications" />

@if (ViewBag.EditErrors != null)
{
    <div class="alert alert-danger">
      <ul>
        @foreach (var msg in ViewBag.EditErrors)
        {
            <li>@msg</li>
        }
      </ul>
    </div>
}




<div class="wrapper">
    <!--Content-Header-->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0 text-dark">
                        قائمة كراسي المكتب

                    </h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Admin/Home/Index">@ResourceWeb.lbHomePage</a></li>

                        <li class="breadcrumb-item active">ادارة كراسي المكتب</li>

                    </ol>
                </div>
            </div>
        </div>
    </div>
    <!--End Content-Header-->
    <!-- Main content -->
    <section class="content">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div  class="card-header d-flex align-items-center justify-content-between">
                         <div>
                             <h3 class="card-title mb-4" style="margin-left:20px">قائمة كراسي المكتب</h3>
                            
                         </div>
                         <div>
                             <!-- Button trigger modal -->
                            <button class="btn btn-info" data-bs-toggle="modal"
                                    data-bs-target="#createModal"
                                    onclick="resetCreateForm()">
                                <i class="las la-plus me-2"></i>أضاافة كرسي
                            </button>
                         </div>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <table id="tableRole" class="table table-bordered table-hover">
                             <thead class="bg-white text-uppercase">
                                <tr>
                                    <th><input type="checkbox" /></th>
                                    <th>@Html.DisplayNameFor(m => m.ImageUrl)</th>
                                    <th>@Html.DisplayNameFor(m => m.Name)</th>
                                    <th>@Html.DisplayNameFor(m => m.Description)</th>
                                    <th>@Html.DisplayNameFor(m => m.IsAvailable)</th>
                                    <th>@Html.DisplayNameFor(m => m.Price)</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>

                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><input type="checkbox" /></td>
                                        <td>
                                            <img src="@item.ImageUrl"
                                                    class="img-fluid rounded-circle"
                                                    alt="Chair"
                                                    width="50" height="50" />
                                        </td>
                                        <td>@item.Name</td>
                                        <td>@item.Description</td>
                                        <td>@(item.IsAvailable ? "Yes" : "No")</td>
                                        <td>@item.Price</td>
                                        <td>
                                            <button type="button"
                                                class="badge bg-success text-white border-0"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal-@item.Id"
                                                onclick="resetCreateForm()">
                                            Edit
                                        </button>



                                            |
                                            <a class="badge bg-info text-white" data-bs-toggle="modal"
                                                    data-bs-target="#viewModal-@item.Id"
                                                    onclick="resetCreateForm()">Details</a>
                                            |
                                            <a class="badge bg-danger text-white"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal-@item.Id">Delete</a>
                                        </td>
                                    </tr>

                                    <!-- DELETE CONFIRMATION MODAL -->
                                    <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content border-danger">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">Delete Chair</h5>
                                                    <button type="button" class="btn-close btn-close-white"
                                                            data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <form asp-action="DeleteConfirmed" asp-route-id="@item.Id" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <div class="modal-body">
                                                        <p>Are you sure you want to delete the chair
                                                            <strong>@item.Name</strong>?</p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-danger">
                                                            Yes, Delete
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
                <!-- /.card -->
            </div>
            <!-- /.col -->
        </div>
        <!-- /.row -->
    </section>
    <!-- /.content -->
</div>


 <!-- CREATE MODAL -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog card card-success card-outline">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Chair</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Admin" asp-controller="ChairsManager" asp-action="Create" method="post" enctype="multipart/form-data" id="createChairForm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Name</label>
                        <input name="Name" class="form-control" required minlength="2" maxlength="100" />
                        <span data-valmsg-for="Name" class="text-danger"></span>
                    </div>
                   <div class="form-group">
                        <label>Description</label>
                        <textarea name="Description" class="form-control" required minlength="5" maxlength="500" rows="4"></textarea>
                        <span data-valmsg-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Price</label>
                        <input name="Price" class="form-control" type="number" min="0" step="0.01" required />
                        <span data-valmsg-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>Image</label>
                        <div class="mb-4 d-flex justify-content-center">
                            <img id="createPreview" src="https://mdbootstrap.com/img/Photos/Others/placeholder.jpg"
                                 alt="image preview" style="width: 300px;" />
                        </div>
                        <div class="d-flex justify-content-center">
                            <div class="btn btn-primary btn-rounded">
                                <label class="form-label text-white m-1" for="createImage">Choose file</label>
                                <input name="ImageFile" type="file" class="form-control d-none"
                                       id="createImage" onchange="previewImage(event, 'createPreview')" accept="image/*" required />
                            </div>
                        </div>
                    </div>
                    <div class="form-check mb-3">
                        <input 
                            type="checkbox" 
                            name="IsAvailable" 
                            value="true"
                            class="form-check-input" 
                            id="isAvailableCheck" />
                        <label 
                            class="form-check-label" 
                            for="isAvailableCheck">
                            Available
                        </label>
                        <input type="hidden" name="IsAvailable" value="false" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>

           

        </div>
    </div>
</div>



<!-- EDIT MODALS -->
@foreach (var chair in Model)
{
    <div class="modal fade" id="editModal-@chair.Id" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog card card-success card-outline">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Edit Chair</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
               <form asp-area="Admin" asp-controller="ChairsManager" asp-action="Edit" 
                    asp-route-id="@chair.Id" method="post" enctype="multipart/form-data" id="editChairForm-@chair.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@chair.Id" />
                <input type="hidden" name="ImageUrl" value="@chair.ImageUrl" />

                <div class="modal-body">
                    <div class="form-group">
                        <label>Name</label>
                        <input name="Name" class="form-control" value="@chair.Name" required minlength="2" maxlength="100" />
                        <span class="text-danger" data-valmsg-for="Name"></span>
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <input name="Description" class="form-control" value="@chair.Description" required minlength="5" maxlength="500" />
                        <span class="text-danger" data-valmsg-for="Description"></span>
                    </div>

                    <div class="form-group">
                        <label>Price</label>
                        <input name="Price" type="number" step="0.01" class="form-control"
                                value="@chair.Price" min="0" required />
                        <span class="text-danger" data-valmsg-for="Price"></span>
                    </div>

                    <div class="form-group">
                            <label>Current Image</label>
                            <div class="mb-4 text-center">
                                <img id="editPreview-@chair.Id" src="@chair.ImageUrl"
                                        style="max-width:300px;" />
                            </div>
                            <div class="text-center">
                                <label class="btn btn-primary">
                                    Choose new image (optional)
                                    <!-- Remove 'required' attribute -->
                                    <input name="ImageFile" type="file" hidden 
                                            onchange="previewImage(event, 'editPreview-@chair.Id')" accept="image/*" />
                                </label>
                            </div>
                     </div>

                    <div class="form-check mb-3">
                        <input type="checkbox" name="IsAvailable" value="true"
                                class="form-check-input" id="isAvailableCheck-@chair.Id" @(chair.IsAvailable ? "checked" : "") />
                        <label class="form-check-label" for="isAvailableCheck-@chair.Id">
                            Available
                        </label>
                        <input type="hidden" name="IsAvailable" value="false" />
                    </div>
                </div>
        
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
            <script>
            // Client-side validation for the edit form
            document.querySelectorAll('[id^="editChairForm-"]').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    let valid = true;
                    const name = this.elements['Name'];
                    const description = this.elements['Description'];
                    const price = this.elements['Price'];

                    // Name validation
                    if (!name.value.trim() || name.value.length < 2 || name.value.length > 100) {
                        valid = false;
                        name.classList.add('is-invalid');
                    } else {
                        name.classList.remove('is-invalid');
                    }

                    // Description validation
                    if (!description.value.trim() || description.value.length < 5 || description.value.length > 500) {
                        valid = false;
                        description.classList.add('is-invalid');
                    } else {
                        description.classList.remove('is-invalid');
                    }

                    // Price validation
                    if (!price.value || isNaN(price.value) || Number(price.value) < 0) {
                        valid = false;
                        price.classList.add('is-invalid');
                    } else {
                        price.classList.remove('is-invalid');
                    }

                    if (!valid) {
                        e.preventDefault();
                    }
                });
            });
             </script>
        </div>
      </div>
    </div>
}
<!-- VIEW MODAL -->
@if (Model != null)
{
    @foreach (var chair in Model)
    {
        <div class="modal fade" id="viewModal-@chair.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog card card-success card-outline">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        <h5 class="modal-title">View Chair</h5>
                    </div>
                    <div class="modal-body">
                        <dl class="row">
                            <dt class="col-sm-4">Name</dt>
                            <dd class="col-sm-8">@chair.Name</dd>
                            <dt class="col-sm-4">Description</dt>
                            <dd class="col-sm-8">@chair.Description</dd>
                            <dt class="col-sm-4">Image</dt>
                            <dd class="col-sm-8"><img src="@chair.ImageUrl" class="img-fluid" /></dd>
                            <dt class="col-sm-4">Available</dt>
                            <dd class="col-sm-8">@(chair.IsAvailable ? "Yes" : "No")</dd>
                        </dl>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/assets/js/app.js"></script>
    <script src="~/Modules/Roles.js"></script>
    <script>
        // Unified image preview function
        function previewImage(event, previewId) {
            const preview = document.getElementById(previewId);
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(file);
            }
        }

        // Reset create form
        function resetCreateForm() {
            const form = document.querySelector('#createModal form');
            if (form) {
                form.reset();
                document.getElementById('createPreview').src =
                    'https://mdbootstrap.com/img/Photos/Others/placeholder.jpg';
            }
        }

        // Client-side validation for the create form
        document.getElementById('createChairForm').addEventListener('submit', function (e) {
            let valid = true;
            const name = this.elements['Name'];
            const description = this.elements['Description'];
            const price = this.elements['Price'];
            const image = this.elements['ImageFile'];

            // Name validation
            if (!name.value.trim() || name.value.length < 2 || name.value.length > 100) {
                valid = false;
                name.classList.add('is-invalid');
            } else {
                name.classList.remove('is-invalid');
            }

            // Description validation
            if (!description.value.trim() || description.value.length < 5 || description.value.length > 500) {
                valid = false;
                description.classList.add('is-invalid');
            } else {
                description.classList.remove('is-invalid');
            }

            // Price validation
            if (!price.value || isNaN(price.value) || Number(price.value) < 0) {
                valid = false;
                price.classList.add('is-invalid');
            } else {
                price.classList.remove('is-invalid');
            }

            // Image validation
            if (!image.value) {
                valid = false;
                image.classList.add('is-invalid');
            } else {
                image.classList.remove('is-invalid');
            }

            if (!valid) {
                e.preventDefault();
            }
        });
    </script>
    <script>
        function resetCreateForm() { var form = document.querySelector('#createModal form'); if (form) form.reset(); }

        function displaySelectedImage(event, elementId) {
            const selectedImage = document.getElementById(elementId);
            const fileInput = event.target;

            if (fileInput.files && fileInput.files[0]) {
                const reader = new FileReader();

                reader.onload = function(e) {
                    selectedImage.src = e.target.result;
                };

                reader.readAsDataURL(fileInput.files[0]);
            }
        }

                jQuery(document).ready(function () {
            ImgUpload();
        });

        function ImgUpload() {
            var imgWrap = "";
            var imgArray = [];

            $('.upload__inputfile').each(function () {
            $(this).on('change', function (e) {
                imgWrap = $(this).closest('.upload__box').find('.upload__img-wrap');
                var maxLength = $(this).attr('data-max_length');

                var files = e.target.files;
                var filesArr = Array.prototype.slice.call(files);
                var iterator = 0;
                filesArr.forEach(function (f, index) {

                if (!f.type.match('image.*')) {
                    return;
                }

                if (imgArray.length > maxLength) {
                    return false
                } else {
                    var len = 0;
                    for (var i = 0; i < imgArray.length; i++) {
                    if (imgArray[i] !== undefined) {
                        len++;
                    }
                    }
                    if (len > maxLength) {
                    return false;
                    } else {
                    imgArray.push(f);

                    var reader = new FileReader();
                    reader.onload = function (e) {
                        var html = "<div class='upload__img-box'><div style='background-image: url(" + e.target.result + ")' data-number='" + $(".upload__img-close").length + "' data-file='" + f.name + "' class='img-bg'><div class='upload__img-close'></div></div></div>";
                        imgWrap.append(html);
                        iterator++;
                    }
                    reader.readAsDataURL(f);
                    }
                }
                });
            });
            });

            $('body').on('click', ".upload__img-close", function (e) {
            var file = $(this).parent().data("file");
            for (var i = 0; i < imgArray.length; i++) {
                if (imgArray[i].name === file) {
                imgArray.splice(i, 1);
                break;
                }
            }
            $(this).parent().parent().remove();
            });
        }
    </script>
    @if (!string.IsNullOrEmpty(Context.Session.GetString(Helper.MsgType)))
    {
        if (Context.Session.GetString(Helper.MsgType) == Helper.Success)
        {
            <script>

                Swal.fire({
                        title: '@Context.Session.GetString(Helper.Title)',
                        text: '@Html.Raw(@Context.Session.GetString(Helper.Msg))',
                        confirmButtonText: '@ResourceWeb.lbOk',
                    icon: 'success'
                });
            </script>

        }
        else
        {
            <script>

                Swal.fire({
                        title: '@Context.Session.GetString(Helper.Title)',
                        text: '@Html.Raw(@Context.Session.GetString(Helper.Msg))',
                        confirmButtonText: '@ResourceWeb.lbOk',
                    icon: 'error'
                });
            </script>
        }
        Context.Session.SetString(Helper.MsgType, "");
    }


    <script>

        let lbTitleEdit = '@Html.Raw(ResourceWeb.lbTitleEdit)';
        let lbEdit = '@Html.Raw(ResourceWeb.lbEdit)';
        let lbAddNewRole = '@Html.Raw(ResourceWeb.lbAddNewRole)';
        let lbbtnSave = '@Html.Raw(ResourceWeb.lbbtnSave)';

        let lbTitleMsgDelete = '@Html.Raw(ResourceWeb.lbbtnSave)';
        let lbTextMsgDelete = '@Html.Raw(ResourceWeb.lbTextMsgDelete)';
        let lbconfirmButtonText = '@Html.Raw(ResourceWeb.lbconfirmButtonText)';
        let lbcancelButtonText = '@Html.Raw(ResourceWeb.lbcancelButtonText)';

        let lbTitleDeletedOk = '@Html.Raw(ResourceWeb.lbTitleDeletedOk)';
        let lbMsgDeletedOkRole = '@Html.Raw(ResourceWeb.lbMsgDeletedOkRole)';
        let lbSuccess = '@Html.Raw(Helper.Success)';

    </script>

}

