@model IEnumerable<Domin.Entity.Product>
@using Domin.Resource
@inject IWebHostEnvironment Env 

@{
    ViewData["Title"] = "Index";
}

<partial name="_Notifications" />

@if (ViewBag.EditErrors != null)
{
    <div class="alert alert-danger">
      <ul>
        @foreach (var msg in ViewBag.EditErrors)
        {
            <li>@msg</li>
        }
      </ul>
    </div>
}

<div class="wrapper">
    <!--Content-Header-->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0 text-dark">
                        قائمة المنتجات
                    </h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Admin/Home/Index">@ResourceWeb.lbHomePage</a></li>
                        <li class="breadcrumb-item active">إدارة المنتجات</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
    <!--End Content-Header-->

    <!-- Main content -->
    <section class="content">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div  class="card-header d-flex align-items-center justify-content-between">
                         <h3 class="card-title mb-0">قائمة المنتجات</h3>
                         <button class="btn btn-info" data-bs-toggle="modal"
                                 data-bs-target="#createModal"
                                 onclick="resetCreateForm()">
                            <i class="las la-plus me-2"></i>@ResourceWeb.lbAddNew
                         </button>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered table-hover">
                             <thead class="bg-white text-uppercase">
                                <tr>
                                    <th><input type="checkbox" /></th>
                                    <th>@Html.DisplayNameFor(m => m.First().ImageUrl)</th>
                                    <th>@Html.DisplayNameFor(m => m.First().Name)</th>
                                    <th>@Html.DisplayNameFor(m => m.First().ProductType.Name)</th>
                                    <th>@Html.DisplayNameFor(m => m.First().Description)</th>
                                    <th>@Html.DisplayNameFor(m => m.First().IsAvailable)</th>
                                    <th>@Html.DisplayNameFor(m => m.First().Price)</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><input type="checkbox" /></td>
                                        <td>
                                            <img src="@item.ImageUrl"
                                                 class="img-fluid rounded-circle"
                                                 alt="@item.Name"
                                                 width="50" height="50" />
                                        </td>
                                        <td>@item.Name</td>
                                        <td>@item.ProductType?.Name</td>
                                        <td>@item.Description</td>
                                        <td>@(item.IsAvailable ? "Yes" : "No")</td>
                                        <td>@item.Price</td>
                                        <td>
                                            <button type="button"
                                                class="badge bg-success text-white border-0"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal-@item.Id"
                                                onclick="resetCreateForm()">
                                              @ResourceWeb.lbEdit
                                            </button>
                                            |
                                            <button class="badge bg-info text-white"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#viewModal-@item.Id"
                                                    onclick="resetCreateForm()">
                                              @ResourceWeb.lbDetails
                                            </button>
                                            |
                                            <button class="badge bg-danger text-white"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal-@item.Id">
                                              @ResourceWeb.lbDelete
                                            </button>
                                        </td>
                                    </tr>

                                    <!-- DELETE CONFIRMATION MODAL -->
                                    <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content border-danger">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">@ResourceWeb.lbDeleteProduct</h5>
                                                    <button type="button" class="btn-close btn-close-white"
                                                            data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <form asp-area="Admin" asp-controller="ProductsManager" asp-action="DeleteConfirmed" asp-route-id="@item.Id" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <div class="modal-body">
                                                        <p>@ResourceWeb.lbConfirmDeleteProduct <strong>@item.Name</strong>?</p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">@ResourceWeb.lbcancelButtonText</button>
                                                        <button type="submit" class="btn btn-danger">
                                                            @ResourceWeb.lbDelete
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- CREATE MODAL -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog card card-success card-outline">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@ResourceWeb.lbNewProduct</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-area="Admin" asp-controller="ProductsManager" asp-action="Create" method="post" enctype="multipart/form-data" id="createProductForm" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>@ResourceWeb.lbName</label>
                        <input name="Name" class="form-control" required minlength="2" maxlength="100" />
                        <span data-valmsg-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbProductType</label>
                        <select name="ProductTypeId" class="form-control" required>
                            <option value="">-- @ResourceWeb.lbSelectType --</option>
                            @if (ViewData["ProductTypeId"] is SelectList types)
                            {
                                foreach (var t in types)
                                {
                                    <option value="@t.Value">@t.Text</option>
                                }
                            }
                        </select>
                        <span data-valmsg-for="ProductTypeId" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbDescription</label>
                        <textarea name="Description" class="form-control" required minlength="5" maxlength="500"></textarea>
                        <span data-valmsg-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbPrice</label>
                        <input name="Price" type="number" class="form-control" step="0.01" min="0" required />
                        <span data-valmsg-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbImage</label>
                        <div class="mb-4 d-flex justify-content-center">
                            <img id="createPreview" src="https://mdbootstrap.com/img/Photos/Others/placeholder.jpg"
                                 alt="image preview" style="width: 300px;" />
                        </div>
                        <div class="d-flex justify-content-center">
                            <label class="btn btn-primary btn-rounded">
                                @ResourceWeb.lbChooseFile
                                <input name="ImageFile" type="file" hidden accept="image/*" onchange="previewImage(event,'createPreview')" required />
                            </label>
                        </div>
                        <span data-valmsg-for="ImageFile" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" name="IsAvailable" value="true" class="form-check-input" id="isAvailableCheck" />
                        <label for="isAvailableCheck" class="form-check-label">@ResourceWeb.lbAvailable</label>
                        <input type="hidden" name="IsAvailable" value="false" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">@ResourceWeb.lbCreate</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODALS -->
@foreach (var product in Model)
{
    <div class="modal fade" id="editModal-@product.Id" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog card card-success card-outline">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">@ResourceWeb.lbEditProduct</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <form asp-area="Admin" asp-controller="ProductsManager" asp-action="Edit" asp-route-id="@product.Id" method="post" enctype="multipart/form-data" id="editProductForm-@product.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@product.Id" />
                <input type="hidden" name="ImageUrl" value="@product.ImageUrl" />

                <div class="modal-body">
                    <div class="form-group">
                        <label>@ResourceWeb.lbName</label>
                        <input name="Name" class="form-control" value="@product.Name" required minlength="2" maxlength="100" />
                        <span data-valmsg-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbProductType</label>
                        <select name="ProductTypeId" class="form-control" required>
                            @if (ViewData["ProductTypeId"] is SelectList types2)
                            {
                                foreach (var t in types2)
                                {
                                    var sel = t.Value == product.ProductTypeId.ToString() ? "selected" : "";
                                    <option value="@t.Value">@t.Text</option>
                                }
                            }
                        </select>
                        <span data-valmsg-for="ProductTypeId" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbDescription</label>
                        <textarea name="Description" class="form-control" required minlength="5" maxlength="500">@product.Description</textarea>
                        <span data-valmsg-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbPrice</label>
                        <input name="Price" type="number" class="form-control" step="0.01" min="0" value="@product.Price" required />
                        <span data-valmsg-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@ResourceWeb.lbCurrentImage</label>
                        <div class="mb-4 text-center">
                            <img id="editPreview-@product.Id" src="@product.ImageUrl" style="max-width:300px;" />
                        </div>
                        <div class="text-center">
                            <label class="btn btn-primary">
                                @ResourceWeb.lbChooseNewImage
                                <input name="ImageFile" type="file" hidden accept="image/*" onchange="previewImage(event,'editPreview-@product.Id')" />
                            </label>
                        </div>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" name="IsAvailable" value="true" class="form-check-input" id="isAvailableCheck-@product.Id" @(product.IsAvailable?"checked":"") />
                        <label for="isAvailableCheck-@product.Id" class="form-check-label">@ResourceWeb.lbAvailable</label>
                        <input type="hidden" name="IsAvailable" value="false" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">@ResourceWeb.lbSave</button>
                </div>
          </form>
        </div>
      </div>
    </div>
}
<!-- VIEW MODAL -->
@foreach (var product in Model)
{
    <div class="modal fade" id="viewModal-@product.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog card card-success card-outline">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@ResourceWeb.lbProductDetails</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-4">@ResourceWeb.lbName</dt>
                        <dd class="col-sm-8">@product.Name</dd>
                        <dt class="col-sm-4">@ResourceWeb.lbProductType</dt>
                        <dd class="col-sm-8">@product.ProductType?.Name</dd>
                        <dt class="col-sm-4">@ResourceWeb.lbDescription</dt>
                        <dd class="col-sm-8">@product.Description</dd>
                        <dt class="col-sm-4">@ResourceWeb.lbAvailable</dt>
                        <dd class="col-sm-8">@(product.IsAvailable ? ResourceWeb.lbYes : ResourceWeb.lbNo)</dd>
                        <dt class="col-sm-4">@ResourceWeb.lbPrice</dt>
                        <dd class="col-sm-8">@product.Price</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@ResourceWeb.lbClose</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(event, previewId) {
            const preview = document.getElementById(previewId);
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = e => preview.src = e.target.result;
                reader.readAsDataURL(file);
            }
        }
        function resetCreateForm() {
            const form = document.querySelector('#createModal form');
            if (form) {
                form.reset();
                document.getElementById('createPreview').src = 'https://mdbootstrap.com/img/Photos/Others/placeholder.jpg';
            }
        }
    </script>
}
