@using System.Text.Json
@model Infrastructure.ViewModel.DashboardViewModel

@{
    ViewData["Title"] = "لوحة التحكم";

    var chartData = new
    {
        monthlyLabels = Model.MonthlyLabels,
        monthlyRevenue = Model.MonthlyRevenue,
        orderStatusLabels = Model.OrderStatusLabels,
        orderStatusCounts = Model.OrderStatusCounts
    };
}

@functions {
    private static string StatusBadgeClass(string status)
    {
        return status switch
        {
            OrderStatuses.Completed => "badge-success",
            OrderStatuses.Cancelled => "badge-danger",
            OrderStatuses.Shipping => "badge-info",
            OrderStatuses.PendingReview => "badge-warning",
            _ => "badge-secondary"
        };
    }
}

<div class="row mb-3">
    <div class="col-sm-6">
        <h1 class="m-0 text-dark">لوحة التحكم</h1>
    </div>
    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">الرئيسية</a></li>
            <li class="breadcrumb-item active">لوحة التحكم</li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.TotalOrders</h3>
                <p>إجمالي الطلبات</p>
            </div>
            <div class="icon">
                <i class="ion ion-bag"></i>
            </div>
            <a asp-area="Admin" asp-controller="OrderManage" asp-action="Index" class="small-box-footer">عرض الطلبات <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.TotalRevenue.ToString("N0")</h3>
                <p>إيرادات مكتملةEGB</p>
            </div>
            <div class="icon">
                <i class="ion ion-stats-bars"></i>
            </div>
            <a asp-area="Admin" asp-controller="OrderManage" asp-action="Index" class="small-box-footer">تفاصيل الإيرادات <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.PendingOrders</h3>
                <p>طلبات قيد الإجراء</p>
            </div>
            <div class="icon">
                <i class="ion ion-alert-circled"></i>
            </div>
            <a asp-area="Admin" asp-controller="OrderManage" asp-action="Index" class="small-box-footer">متابعة الطلبات <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box bg-primary">
            <div class="inner">
                <h3>@Model.CompletedOrders</h3>
                <p>طلبات مكتملة</p>
            </div>
            <div class="icon">
                <i class="ion ion-checkmark-circled"></i>
            </div>
            <a asp-area="Admin" asp-controller="OrderManage" asp-action="Index" class="small-box-footer">عرض المكتملة <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box bg-secondary">
            <div class="inner">
                <h3>@Model.TotalUsers</h3>
                <p>المستخدمون</p>
            </div>
            <div class="icon">
                <i class="ion ion-person-add"></i>
            </div>
            <a asp-area="Admin" asp-controller="Accounts" asp-action="Registers" class="small-box-footer">إدارة المستخدمين <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>@Model.TotalProducts</h3>
                <p>المنتجات</p>
            </div>
            <div class="icon">
                <i class="ion ion-pie-graph"></i>
            </div>
            <a asp-area="Admin" asp-controller="ProductsManager" asp-action="Index" class="small-box-footer">إدارة المنتجات <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<div class="row">
    <section class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-line mr-1"></i>
                    إيرادات الطلبات المكتملة
                </h3>
            </div>
            <div class="card-body">
                <div class="chart" style="position: relative; height: 320px;">
                    <canvas id="dashboard-revenue-chart" height="320"></canvas>
                </div>
            </div>
        </div>
    </section>

    <section class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-pie mr-1"></i>
                    حالات الطلبات
                </h3>
            </div>
            <div class="card-body">
                <div class="chart mb-3" style="position: relative; height: 260px;">
                    <canvas id="dashboard-status-chart" height="260"></canvas>
                </div>

                @if (Model.OrderStatusLabels.Any())
                {
                    <ul class="list-group list-group-flush">
                        @for (var i = 0; i < Model.OrderStatusLabels.Count; i++)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>@Model.OrderStatusLabels[i]</span>
                                <span class="badge @StatusBadgeClass(Model.OrderStatusLabels[i]) badge-pill">@Model.OrderStatusCounts[i]</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">لا توجد طلبات حتى الآن.</p>
                }
            </div>
        </div>
    </section>
</div>

<div class="row">
    <section class="col-lg-8">
        <div class="card">
            <div class="card-header border-transparent">
                <h3 class="card-title">
                    <i class="fas fa-receipt mr-1"></i>
                    أحدث الطلبات
                </h3>
                <div class="card-tools">
                    <a asp-area="Admin" asp-controller="OrderManage" asp-action="Index" class="btn btn-tool" title="عرض كل الطلبات">
                        <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentOrders.Any())
                {
                    <div class="table-responsive">
                        <table class="table m-0">
                            <thead>
                                <tr>
                                    <th>رقم الطلب</th>
                                    <th>العميل</th>
                                    <th>الحالة</th>
                                    <th>الإجمالي</th>
                                    <th>التاريخ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td>
                                            <a asp-area="Admin" asp-controller="OrderManage" asp-action="Details" asp-route-id="@order.Id">#@order.Id</a>
                                        </td>
                                        <td>@order.CustomerName</td>
                                        <td><span class="badge @StatusBadgeClass(order.OrderStatus)">@order.OrderStatus</span></td>
                                        <td>@order.Total.ToString("N0") EGB</td>
                                        <td>@order.OrderDate.ToString("yyyy/MM/dd")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">لا توجد طلبات حديثة.</p>
                }
            </div>
        </div>
    </section>

    <section class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-box-open mr-1"></i>
                    أكثر المنتجات مبيعا
                </h3>
            </div>
            <div class="card-body p-0">
                @if (Model.TopProducts.Any())
                {
                    <table class="table m-0">
                        <thead>
                            <tr>
                                <th>المنتج</th>
                                <th class="text-center">الكمية</th>
                                <th class="text-right">الإيراد</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.TopProducts)
                            {
                                <tr>
                                    <td>@product.ProductName</td>
                                    <td class="text-center">@product.QuantitySold</td>
                                    <td class="text-right">@product.Revenue.ToString("N0")EGB</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">لا توجد مبيعات مكتملة بعد.</p>
                }
            </div>
        </div>
    </section>
</div>

<script type="application/json" id="dashboard-chart-data">
    @Html.Raw(JsonSerializer.Serialize(chartData))
</script>

@section Scripts {
    <script src="~/Admin/js/admin-dashboard.js" asp-append-version="true"></script>
}
