@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}


<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>adminLTE 3 | Log in</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/admin/plugins//fontawesome-free/css/all.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <!-- icheck bootstrap -->
    <link rel="stylesheet" href="~/admin/plugins//icheck-bootstrap/icheck-bootstrap.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/admin/dist/css/adminlte.min.css">
    <!-- Google Font: Source Sans Pro -->
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700" rel="stylesheet">
</head>
<body class="hold-transition login-page">
    <div class="login-box">
        <div class="login-logo">
            <a href="../../index2.html"><b>Admin</b>LTE</a>
        </div>
        <div class="card">
            <div class="card-body login-card-body">
                <p class="login-box-msg">Sign in to start your session</p>

                <!-- FIX: Remove asp-area, asp-controller, asp-action for Razor Pages -->
                <form asp-controller="Accounts" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-sucsess" })
                    <div class="input-group mb-3">
                        <input asp-for="Email"
                               type="email"
                               class="form-control"
                               placeholder="Email" />
                        <span class="text-danger" asp-validation-for="Email"></span>
                    </div>

                    <div class="input-group mb-3">
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="Password" />
                        <span class="text-danger" asp-validation-for="Password"></span>
                    </div>

                    <div class="row">
                        <div class="col-8">
                            <div class="form-check">
                                <input asp-for="RememberMy"
                                       class="form-check-input"
                                       id="remember" />
                                <label class="form-check-label" for="remember">
                                    Remember Me
                                </label>
                            </div>
                        </div>
                        <div class="col-4">
                            <input type="submit" class="btn btn-success" value="Sign In" id="btnSave" />
                        </div>
                    </div>
                </form>

                <div class="social-auth-links text-center mb-3">
                    <p>- OR -</p>
                    <a href="#" class="btn btn-block btn-primary">
                        <i class="fab fa-facebook mr-2"></i> Sign in using Facebook
                    </a>
                    <a href="#" class="btn btn-block btn-danger">
                        <i class="fab fa-google-plus mr-2"></i> Sign in using Google+
                    </a>
                </div>

                <p class="mb-1">
                    <a href="#">I forgot my password</a>
                </p>
                <p class="mb-0">
                    <a asp-page="/Admin/Accounts/Registers" class="text-center">Register a new membership</a>
                </p>
            </div>
        </div>
    </div>
    <script src="~/admin/plugins//jquery/jquery.min.js"></script>
    <script src="~/admin/plugins//bootstrap/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
