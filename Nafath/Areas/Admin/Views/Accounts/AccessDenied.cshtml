@page
@model Nafath.Areas.Admin.Views.Accounts.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied - Nafath";
    Layout = "~/Views/Shared/_Layoutadmin.cshtml"; 
}

@section Styles {
    <style>
        .access-denied-container {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        }

        .access-denied-card {
            max-width: 520px;
            width: 100%;
            text-align: center;
            padding: 3rem 2rem;
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 1px solid #e2e8f0;
        }

        .icon-container {
            width: 120px;
            height: 120px;
            margin: 0 auto 1.5rem;
            background: #fee2e2;
            color: #ef4444;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
        }

        .error-code {
            font-size: 5rem;
            font-weight: 700;
            color: #64748b;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        h1 {
            color: #1e2937;
            margin-bottom: 1rem;
        }

        .lead {
            color: #64748b;
            font-size: 1.1rem;
            margin-bottom: 2rem;
        }

        .btn-group .btn {
            padding: 0.75rem 2rem;
            font-weight: 500;
            border-radius: 8px;
        }
    </style>
}

<div class="access-denied-container">
    <div class="access-denied-card">
        <div class="icon-container">
            <i class="fas fa-lock"></i>
        </div>

        <div class="error-code">403</div>
        <h1>غير مصرح بالدخول</h1>
        <p class="lead">
            عذراً، ليس لديك الصلاحيات اللازمة للوصول إلى هذه الصفحة.
        </p>

        <div class="btn-group d-flex justify-content-center gap-3">


            <a asp-area="" asp-controller="" asp-action="Index"
               class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>
                العودة للصفحة الرئيسية
            </a>
        </div>

        <hr class="my-4" />

        <div class="text-muted small">
            إذا كنت تعتقد أن هذا خطأ، يرجى التواصل مع مدير النظام.
        </div>

        <div class="mt-3">
           
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // يمكنك إضافة أي JavaScript إضافي هنا
        document.addEventListener('DOMContentLoaded', function () {
            console.log('%cAccess Denied - Nafath Admin', 'color: #ef4444; font-weight: bold;');
        });
    </script>
}